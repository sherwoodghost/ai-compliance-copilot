# ─── Backend Connection ───────────────────────────────────────────────────────
# URL of the NestJS API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# WebSocket base URL for real-time notifications (compliance gateway)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ─── Collaborative Editing (P22) ─────────────────────────────────────────────
# Hocuspocus WebSocket server URL (only needed if COLLABORATION_ENABLED=true on backend)
# NEXT_PUBLIC_COLLABORATION_URL=ws://localhost:1234
