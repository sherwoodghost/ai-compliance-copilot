// ─── Inference Results ────────────────────────────────────────────────────────

model InferenceResult {
  id                  String   @id @default(uuid())
  orgId               String   @map("org_id")
  onboardingVersion   Int      @default(1) @map("onboarding_version")
  riskLevel           String   @map("risk_level")         // LOW/MEDIUM/HIGH
  riskScore           Int      @default(0) @map("risk_score")
  riskDrivers         Json     @default("[]") @map("risk_drivers")
  inferredFrameworks  Json     @default("[]") @map("inferred_frameworks")
  dataClassification  String   @map("data_classification") // PUBLIC/INTERNAL/CONFIDENTIAL/SENSITIVE
  requiredControls    Json     @default("[]") @map("required_controls")
  expectedIntegrations Json    @default("[]") @map("expected_integrations")
  systemFlags         Json     @default("{}") @map("system_flags")
  engineVersion       String   @default("1.0.0") @map("engine_version")
  computedAt          DateTime @default(now()) @map("computed_at")
  createdAt           DateTime @default(now()) @map("created_at")

  organization         Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integrationSuggestions IntegrationSuggestion[]

  @@index([orgId])
  @@map("inference_results")
}

// ─── Integration Suggestions ──────────────────────────────────────────────────

model IntegrationSuggestion {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  inferenceResultId String?  @map("inference_result_id")
  provider          String
  category          String   // identity/cloud/code/monitoring/ticketing/hr
  reason            String   @db.Text
  priority          String   @default("MEDIUM") // HIGH/MEDIUM/LOW
  controlsSatisfied Json     @default("[]") @map("controls_satisfied")
  setupComplexity   String   @default("MEDIUM") @map("setup_complexity") // LOW/MEDIUM/HIGH
  status            String   @default("suggested") // suggested/dismissed/planned/connected
  dismissedAt       DateTime? @map("dismissed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inferenceResult InferenceResult? @relation(fields: [inferenceResultId], references: [id])

  @@unique([orgId, provider])
  @@map("integration_suggestions")
}

// ─── Control Test Engine ──────────────────────────────────────────────────────

enum TestOutcome {
  pass
  fail
  error
  skipped
}

model ControlTestDefinition {
  id                String   @id @default(uuid())
  testId            String   @unique @map("test_id")       // e.g. "github-branch-protection"
  controlCode       String   @map("control_code")          // e.g. "CC8.1"
  name              String
  description       String   @db.Text
  frequencyCron     String   @default("0 */6 * * *") @map("frequency_cron")  // default: every 6h
  requiresConnector String?  @map("requires_connector")    // "github" | "aws" | null (DB-only)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  results ControlTestResult[]

  @@map("control_test_definitions")
}

model ControlTestResult {
  id           String      @id @default(uuid())
  orgId        String      @map("org_id")
  testId       String      @map("test_id")
  controlCode  String      @map("control_code")
  outcome      TestOutcome
  details      Json        @default("{}")
  evidenceId   String?     @map("evidence_id")
  errorMessage String?     @db.Text @map("error_message")
  durationMs   Int?        @map("duration_ms")
  testedAt     DateTime    @default(now()) @map("tested_at")

  organization Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  definition   ControlTestDefinition @relation(fields: [testId], references: [testId])
  evidence     Evidence?            @relation(fields: [evidenceId], references: [id])

  @@index([orgId, controlCode])
  @@index([orgId, testId])
  @@map("control_test_results")
}

// ─── Trust Center ─────────────────────────────────────────────────────────────

model TrustCenter {
  id           String    @id @default(uuid())
  orgId        String    @unique @map("org_id")
  slug         String    @unique                // URL: /trust/{slug}
  isPublic     Boolean   @default(false) @map("is_public")
  companyName  String    @map("company_name")
  logoUrl      String?   @map("logo_url")
  primaryColor String    @default("#6366f1") @map("primary_color")
  headline     String    @default("Our Commitment to Security & Compliance")
  description  String?   @db.Text
  showControls Boolean   @default(true) @map("show_controls")
  showEvidence Boolean   @default(false) @map("show_evidence")
  publishedAt  DateTime? @map("published_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accessLinks  TrustCenterAccessLink[]

  @@map("trust_centers")
}

model TrustCenterAccessLink {
  id            String    @id @default(uuid())
  trustCenterId String    @map("trust_center_id")
  token         String    @unique
  label         String                             // e.g. "Shared with Acme Auditors"
  expiresAt     DateTime? @map("expires_at")
  viewCount     Int       @default(0) @map("view_count")
  createdAt     DateTime  @default(now()) @map("created_at")

  trustCenter TrustCenter @relation(fields: [trustCenterId], references: [id], onDelete: Cascade)

  @@map("trust_center_access_links")
}

// ─── Control Exceptions ───────────────────────────────────────────────────────

model ControlException {
  id                   String    @id @default(uuid())
  orgId                String    @map("org_id")
  controlId            String    @map("control_id")
  title                String
  justification        String    @db.Text
  compensatingControl  String?   @db.Text @map("compensating_control")
  riskOwnerId          String?   @map("risk_owner_id")
  reviewerId           String?   @map("reviewer_id")
  status               String    @default("pending") // pending/approved/rejected/expired
  expiresAt            DateTime? @map("expires_at")
  approvedAt           DateTime? @map("approved_at")
  rejectedAt           DateTime? @map("rejected_at")
  rejectionReason      String?   @db.Text @map("rejection_reason")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control      @relation(fields: [controlId], references: [id])
  riskOwner    User?        @relation("ExceptionRiskOwner", fields: [riskOwnerId], references: [id])
  reviewer     User?        @relation("ExceptionReviewer", fields: [reviewerId], references: [id])

  @@index([orgId, status])
  @@map("control_exceptions")
}

// ─── Auditor Portal ───────────────────────────────────────────────────────────

model AuditorSession {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  token       String    @unique
  auditorName String    @map("auditor_name")
  auditorFirm String?   @map("auditor_firm")
  auditorEmail String?  @map("auditor_email")
  expiresAt   DateTime  @map("expires_at")
  isRevoked   Boolean   @default(false) @map("is_revoked")
  createdBy   String    @map("created_by")
  lastAccessAt DateTime? @map("last_access_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      User         @relation("AuditorSessionCreator", fields: [createdBy], references: [id])
  rfis         AuditorRfi[]

  @@index([orgId])
  @@map("auditor_sessions")
}

model AuditorRfi {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  auditorSessionId String    @map("auditor_session_id")
  controlId        String?   @map("control_id")
  question         String    @db.Text
  status           String    @default("open") // open/in_review/resolved/closed
  response         String?   @db.Text
  respondedBy      String?   @map("responded_by")
  respondedAt      DateTime? @map("responded_at")
  priority         String    @default("medium") // low/medium/high
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  auditorSession AuditorSession @relation(fields: [auditorSessionId], references: [id], onDelete: Cascade)
  control        Control?       @relation(fields: [controlId], references: [id])
  responder      User?          @relation("RfiResponder", fields: [respondedBy], references: [id])

  @@index([orgId, status])
  @@map("auditor_rfis")
}

// ─── OAuth State ──────────────────────────────────────────────────────────────
// Short-lived state tokens for OAuth flows (stored in DB, cleaned up after use)

model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  provider  String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([state])
  @@map("oauth_states")
}

// ─── LLM Budget (Per-Tenant Cost Governance) ──────────────────────────────────

model LlmBudget {
  id                    String   @id @default(uuid())
  orgId                 String   @unique @map("org_id")
  dailyCapUsd           Decimal  @default(5) @map("daily_cap_usd") @db.Decimal(10, 4)
  monthlyCapUsd         Decimal  @default(50) @map("monthly_cap_usd") @db.Decimal(10, 4)
  ratePerMinuteLimit    Int      @default(30) @map("rate_per_minute_limit")
  currentDaySpendUsd    Decimal  @default(0) @map("current_day_spend_usd") @db.Decimal(10, 6)
  currentMonthSpendUsd  Decimal  @default(0) @map("current_month_spend_usd") @db.Decimal(10, 6)
  capHitAt              DateTime? @map("cap_hit_at")
  lastResetAt           DateTime  @default(now()) @map("last_reset_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("llm_budgets")
}

// ─── Compliance Memory (Audit Cycle History) ──────────────────────────────────

model AuditCycle {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  framework   String                          // SOC2/ISO27001/HIPAA etc
  label       String                          // e.g. "FY2024 SOC 2 Type II"
  status      String    @default("active")    // active/completed/cancelled
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  auditorName String?   @map("auditor_name")
  auditorFirm String?   @map("auditor_firm")
  notes       String?   @db.Text
  outcome     String?                         // clean/qualified/adverse/disclaimer
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      User          @relation("AuditCycleCreator", fields: [createdBy], references: [id])
  findings     AuditFinding[]

  @@index([orgId])
  @@map("audit_cycles")
}

model AuditFinding {
  id              String    @id @default(uuid())
  auditCycleId    String    @map("audit_cycle_id")
  orgId           String    @map("org_id")
  controlId       String?   @map("control_id")
  findingType     String    @map("finding_type")   // deficiency/observation/recommendation/exception
  severity        String    @default("medium")      // critical/high/medium/low/informational
  title           String
  description     String    @db.Text
  remediation     String?   @db.Text               // what was done to fix it
  lessonLearned   String?   @db.Text @map("lesson_learned")
  status          String    @default("open")        // open/in_progress/resolved/accepted
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?   @map("resolved_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  auditCycle  AuditCycle   @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control     Control?     @relation(fields: [controlId], references: [id])
  resolver    User?        @relation("FindingResolver", fields: [resolvedBy], references: [id])

  @@index([orgId, status])
  @@map("audit_findings")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE D — TEAM MANAGEMENT + GUIDED COMPLIANCE ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Evidence Multi-Control Join Table ────────────────────────────────────────

model ControlEvidence {
  id         String   @id @default(uuid())
  evidenceId String   @map("evidence_id")
  controlId  String   @map("control_id")
  orgId      String   @map("org_id")
  confidence Int      @default(100)     // AI-assigned 0-100
  mappedBy   String?  @map("mapped_by") // user ID or 'ai'
  createdAt  DateTime @default(now()) @map("created_at")

  evidence     Evidence     @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  control      Control      @relation(fields: [controlId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, controlId])
  @@index([orgId])
  @@map("control_evidence")
}

// ─── RACI Assignments ─────────────────────────────────────────────────────────

model RaciAssignment {
  id         String     @id @default(uuid())
  orgId      String     @map("org_id")
  controlId  String     @map("control_id")
  userId     String     @map("user_id")
  raci       RaciLetter
  assignedBy String     @map("assigned_by")
  assignedAt DateTime   @default(now()) @map("assigned_at")

  user         User         @relation(fields: [userId], references: [id])
  control      Control      @relation(fields: [controlId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, controlId, userId, raci])
  @@index([orgId, controlId])
  @@map("raci_assignments")
}

// ─── Compliance Responsibilities ──────────────────────────────────────────────

model ComplianceResponsibility {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  orgId      String         @map("org_id")
  role       ComplianceRole
  isPrimary  Boolean        @default(false) @map("is_primary")
  assignedBy String         @map("assigned_by")
  assignedAt DateTime       @default(now()) @map("assigned_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, role, userId])
  @@index([orgId])
  @@map("compliance_responsibilities")
}

// ─── Team Audit Log ───────────────────────────────────────────────────────────

model TeamAuditLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  actorId    String   @map("actor_id")
  action     String   // "role.change" | "raci.assign" | "user.invite" | "sod.violation.blocked" | ...
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  before     Json?
  after      Json?
  reason     String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor        User         @relation("TeamAuditActor", fields: [actorId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, actorId])
  @@map("team_audit_log")
}

// ─── Access Reviews ───────────────────────────────────────────────────────────

model AccessReview {
  id            String             @id @default(uuid())
  orgId         String             @map("org_id")
  reviewerId    String             @map("reviewer_id") // manager conducting review
  dueDate       DateTime           @map("due_date")
  completedAt   DateTime?          @map("completed_at")
  signedAt      DateTime?          @map("signed_at")
  signatureHash String?            @map("signature_hash") // HMAC-SHA256
  status        AccessReviewStatus @default(pending)
  evidenceId    String?            @map("evidence_id") // auto-generated on sign-off

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reviewer     User               @relation("AccessReviewer", fields: [reviewerId], references: [id])
  items        AccessReviewItem[]

  @@index([orgId, status])
  @@map("access_reviews")
}

model AccessReviewItem {
  id          String          @id @default(uuid())
  reviewId    String          @map("review_id")
  userId      String          @map("user_id") // user being reviewed
  system      String          // "GitHub", "AWS Console", etc.
  accessLevel String          @map("access_level") // "Admin", "Read-only", etc.
  lastUsedAt  DateTime?       @map("last_used_at")
  decision    ReviewDecision?
  reason      String?
  createdAt   DateTime        @default(now()) @map("created_at")

  review AccessReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User         @relation("AccessReviewItemUser", fields: [userId], references: [id])

  @@index([reviewId])
  @@map("access_review_items")
}

// ─── Training ─────────────────────────────────────────────────────────────────

model TrainingModule {
  id          String       @id @default(uuid())
  title       String
  kind        TrainingKind
  durationMin Int          @map("duration_min")
  controls    String[]     // control codes this satisfies
  content     Json         // { sections: [...] }
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  assignments TrainingAssignment[]

  @@map("training_modules")
}

model TrainingAssignment {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  userId      String    @map("user_id")
  moduleId    String    @map("module_id")
  assignedBy  String    @map("assigned_by")
  dueDate     DateTime  @map("due_date")
  completedAt DateTime? @map("completed_at")
  score       Int?
  evidenceId  String?   @map("evidence_id") // auto-generated on completion
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User          @relation("TrainingAssignee", fields: [userId], references: [id])
  assignor     User          @relation("TrainingAssignedBy", fields: [assignedBy], references: [id])
  module       TrainingModule @relation(fields: [moduleId], references: [id])

  @@index([orgId, userId])
  @@map("training_assignments")
}

// ─── Policy Templates ─────────────────────────────────────────────────────────

model PolicyTemplate {
  id        String   @id @default(uuid())
  title     String
  controls  String[] // control codes this policy satisfies (e.g. ["A.5.1","CC1.1"])
  content   String   @db.Text // markdown with {{variable}} placeholders
  framework String   // "ISO27001" | "SOC2" | "BOTH"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  policies Policy[]

  @@map("policy_templates")
}

// ─── Control Operating Effectiveness ──────────────────────────────────────────

model ControlEffectivenessSample {
  id        String       @id @default(uuid())
  orgId     String       @map("org_id")
  controlId String       @map("control_id")
  sampledAt DateTime     @map("sampled_at")
  result    SampleResult
  method    String       // "integration_check" | "manual_review" | "automated_test"
  notes     String?
  evidenceId String?     @map("evidence_id")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, controlId, sampledAt])
  @@map("control_effectiveness_samples")
}

// ─── Management Reviews (ISO Clause 9.3) ──────────────────────────────────────

model ManagementReview {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  scheduledAt DateTime  @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  attendees   String[]
  agendaItems Json      @map("agenda_items") // standard ISO 9.3 input items
  minutes     String?   @db.Text            // markdown
  actions     Json      @default("[]")       // [{ item, owner, dueDate, status }]
  signedBy    String?   @map("signed_by")
  evidenceId  String?   @map("evidence_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("management_reviews")
}
