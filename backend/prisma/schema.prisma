  @@map("iso_statement_of_applicability")
}

// ─── Prompt Registry ──────────────────────────────────────────────────────────

model PromptTemplate {
  id                 String   @id @default(uuid())
  templateId         String   @map("template_id")  // e.g. "onboarding-dialogue"
  version            String   // e.g. "v1", "v2"
  agentName          String?  @map("agent_name")
  purpose            String?  @db.Text
  taskType           String?  @map("task_type")
  systemPrompt       String   @db.Text @map("system_prompt")
  userPromptTemplate String?  @db.Text @map("user_prompt_template")
  inputVariables     Json     @default("[]") @map("input_variables")
  outputSchemaId     String?  @map("output_schema_id")
  contentHash        String   @map("content_hash")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  createdBy          String?  @map("created_by")

  llmCalls LlmCall[]

  @@unique([templateId, version])
  @@map("prompt_templates")
}

// ─── LLM Gateway Logging ──────────────────────────────────────────────────────

model LlmCall {
  id                        String   @id @default(uuid())
  orgId                     String?  @map("org_id")
  workflowId                String?  @map("workflow_id")
  agentRunId                String?  @map("agent_run_id")
  taskType                  String?  @map("task_type")
  promptTemplateId          String?  @map("prompt_template_id")
  promptTemplateVersion     String?  @map("prompt_template_version")
  promptHash                String?  @map("prompt_hash")
  renderedPrompt            Json?    @map("rendered_prompt")  // exact messages sent
  model                     String?
  provider                  String?
  inputTokens               Int?     @map("input_tokens")
  outputTokens              Int?     @map("output_tokens")
  costUsd                   Decimal? @map("cost_usd") @db.Decimal(10, 6)
  latencyMs                 Int?     @map("latency_ms")
  requiresRetrieval         Boolean  @default(false) @map("requires_retrieval")
  requiresControlValidation Boolean  @default(false) @map("requires_control_validation")
  schemaValid               Boolean? @map("schema_valid")
  controlIdsValid           Boolean? @map("control_ids_valid")
  hallucinationDetected     Boolean  @default(false) @map("hallucination_detected")
  forbiddenLanguageDetected Boolean  @default(false) @map("forbidden_language_detected")
  retryCount                Int      @default(0) @map("retry_count")
  rawOutput                 String?  @db.Text @map("raw_output")
  createdAt                 DateTime @default(now()) @map("created_at")

  promptTemplate   PromptTemplate?      @relation(fields: [promptTemplateId, promptTemplateVersion], references: [templateId, version])
  retrievalSources LlmRetrievalSource[]
  evalResult       LlmEvalResult?

  @@map("llm_calls")
}

model LlmRetrievalSource {
  id               String   @id @default(uuid())
  llmCallId        String   @map("llm_call_id")
  sourceType       String   @map("source_type") // control_library/policy_template/evidence/agent_output/business_profile/risk_register
  sourceId         String?  @map("source_id")
  chunkId          String?  @map("chunk_id")
  similarityScore  Float?   @map("similarity_score")
  includedInPrompt Boolean  @default(true) @map("included_in_prompt")
  chunkText        String?  @db.Text @map("chunk_text")
  createdAt        DateTime @default(now()) @map("created_at")

  llmCall LlmCall @relation(fields: [llmCallId], references: [id], onDelete: Cascade)

  @@map("llm_retrieval_sources")
}

model LlmEvalResult {
  id                       String   @id @default(uuid())
  llmCallId                String?  @unique @map("llm_call_id")   // nullable — static eval cases have no real call
  evalRunId                String?  @map("eval_run_id")
  schemaValid              Boolean? @map("schema_valid")
  controlIdsValid          Boolean? @map("control_ids_valid")
  hallucinationDetected    Boolean? @map("hallucination_detected")
  forbiddenLanguageDetected Boolean? @map("forbidden_language_detected")
  citationsValid           Boolean? @map("citations_valid")
  humanOverridden          Boolean  @default(false) @map("human_overridden")
  correctnessScore         Float?   @map("correctness_score")
  notes                    String?  @db.Text
  createdAt                DateTime @default(now()) @map("created_at")

  llmCall LlmCall? @relation(fields: [llmCallId], references: [id], onDelete: SetNull)

  @@map("llm_eval_results")
}

// ─── Vector Embeddings (RAG) ──────────────────────────────────────────────────
// Note: actual vector column added via raw SQL migration (pgvector)

model VectorEmbedding {
  id          String   @id @default(uuid())
  orgId       String?  @map("org_id")  // NULL = global (control library, templates)
  sourceType  String   @map("source_type") // control/policy_template/evidence/agent_output/business_profile/risk_register
  sourceId    String?  @map("source_id")
  chunkIndex  Int      @default(0) @map("chunk_index")
  chunkText   String   @db.Text @map("chunk_text")
  metadata    Json     @default("{}")
  // embedding VECTOR(1536) — added via raw SQL migration
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orgId, sourceType])
  @@map("vector_embeddings")
}

// ─── Readiness Scoring ────────────────────────────────────────────────────────

model ReadinessScore {
  id                   String   @id @default(uuid())
