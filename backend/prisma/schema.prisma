model Iso27001Scope {
  id                  String    @id @default(uuid())
  orgId               String    @map("org_id")
  ismsScope           String?   @db.Text @map("isms_scope")
  boundaries          String?   @db.Text
  interestedParties   Json      @default("[]") @map("interested_parties")
