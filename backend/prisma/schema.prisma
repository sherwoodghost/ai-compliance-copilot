model IsoStatementOfApplicability {
  id                   String   @id @default(uuid())
  orgId                String   @map("org_id")
  isoScopeId           String   @map("iso_scope_id")
  controlId            String   @map("control_id")
  applicable           Boolean
  applicabilityRationale String? @db.Text @map("applicability_rationale")
  implementationStatus String?  @map("implementation_status")
  evidenceReferences   Json     @default("[]") @map("evidence_references")
  version              Int      @default(1)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
