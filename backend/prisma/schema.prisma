// ─── Agent Memory (Shared Agent Memory Layer) ─────────────────────────────────

model AgentMemory {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  workflowRunId   String    @map("workflow_run_id")
  agentId         String    @map("agent_id")
  step            Int       @default(0)
  namespace       String    // "inference", "scoping", "evidence", etc.
  key             String
  valueJson       Json      @map("value_json")
  schemaVersion   String    @default("v1") @map("schema_version")
  ttlAt           DateTime? @map("ttl_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([workflowRunId, namespace, key])
  @@index([workflowRunId], name: "idx_agent_memory_wf")
  @@index([organizationId], name: "idx_agent_memory_org")
  @@map("agent_memory")
