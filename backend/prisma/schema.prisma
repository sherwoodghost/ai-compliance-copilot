// ─── Risk Treatments ──────────────────────────────────────────────────────────

model RiskTreatment {
  id                    String    @id @default(uuid())
  riskId                String    @map("risk_id")
  orgId                 String    @map("org_id")
  treatmentType         String    @map("treatment_type")  // mitigate/accept/transfer/avoid
