// ─── Control Library Extensions ───────────────────────────────────────────────

model ControlDomain {
  id                   String  @id @default(uuid())
  frameworkId          String  @map("framework_id")
  code                 String  // e.g. "CC6", "A.5"
  name                 String
  trustServiceCategory String? @map("trust_service_category") // SOC2 only
  description          String? @db.Text
  sortOrder            Int     @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")

  framework    Framework            @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  libraryMetas ControlLibraryMeta[]

  @@unique([frameworkId, code])
  @@map("control_domains")
}

// Extends existing Control table with library metadata
model ControlLibraryMeta {
  id                 String   @id @default(uuid())
  controlId          String   @unique @map("control_id")
  domainId           String?  @map("domain_id")
  applicabilityNotes String?  @db.Text @map("applicability_notes")
  confidence         String   @default("high")  // high/medium/low
  sourceReference    String?  @db.Text @map("source_reference")
  importedAt         DateTime @default(now()) @map("imported_at")

  control Control       @relation(fields: [controlId], references: [id], onDelete: Cascade)
  domain  ControlDomain? @relation(fields: [domainId], references: [id])

  @@map("control_library_meta")
}

model ControlEvidenceRequirement {
  id            String  @id @default(uuid())
  controlId     String  @map("control_id")
  evidenceType  String  @map("evidence_type")  // policy_doc/config_export/log/screenshot/etc
  description   String? @db.Text
  isMandatory   Boolean @default(true) @map("is_mandatory")
  freshnessDays Int?    @map("freshness_days")  // max age in days
  createdAt     DateTime @default(now()) @map("created_at")

  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("control_evidence_requirements")
}

model ControlPolicyRequirement {
  id          String  @id @default(uuid())
  controlId   String  @map("control_id")
  policyName  String  @map("policy_name")
  description String? @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@map("control_policy_requirements")
}

model FrameworkCrosswalk {
  id               String  @id @default(uuid())
  sourceControlId  String  @map("source_control_id")
  targetControlId  String  @map("target_control_id")
  mappingType      String  @default("related") @map("mapping_type") // equivalent/partial/related
  confidence       String  @default("high")
  rationale        String? @db.Text
  automatable      Boolean @default(false)
  createdAt        DateTime @default(now()) @map("created_at")

  sourceControl Control @relation("CrosswalkSource", fields: [sourceControlId], references: [id], onDelete: Cascade)
  targetControl Control @relation("CrosswalkTarget", fields: [targetControlId], references: [id], onDelete: Cascade)

  @@unique([sourceControlId, targetControlId])
  @@map("framework_crosswalks")
}

// ─── Control Applicability ─────────────────────────────────────────────────────

model ControlApplicability {
  id                  String   @id @default(uuid())
  orgId               String   @map("org_id")
  controlId           String   @map("control_id")
  applicable          Boolean
  applicabilityStatus String   @default("needs_review") @map("applicability_status") // applicable/not_applicable/needs_review
  rationale           String?  @db.Text
  overriddenBy        String?  @map("overridden_by")  // userId who manually overrode
  overriddenAt        DateTime? @map("overridden_at")
  confidence          String   @default("high")
  requiresHumanReview Boolean  @default(false) @map("requires_human_review")
  profileVersionUsed  Int?     @map("profile_version_used")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  overriddenByUser User?    @relation("ApplicabilityOverride", fields: [overriddenBy], references: [id])

  @@unique([orgId, controlId])
  @@map("control_applicability")
}

