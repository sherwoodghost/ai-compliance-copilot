// ─── Tenancy Layer ────────────────────────────────────────────────────────────

model Organization {
  id                String           @id @default(uuid())
  name              String
  slug              String           @unique
  plan              Plan             @default(starter)
  subscriptionTier  SubscriptionTier @default(free) @map("subscription_tier")
  settings          Json             @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  sessions            Session[]
  businessProfile     BusinessProfile?
  onboardingSessions  OnboardingSession[]
  organizationControls OrganizationControl[]
  evidence            Evidence[]
  policies            Policy[]
  workflows           Workflow[]
  agentRuns           AgentRun[]
  tasks               Task[]
  integrations        Integration[]
  riskItems           RiskItem[]
  vendorRisks         VendorRisk[]
  auditLogs           AuditLog[]
  systemLogs          SystemLog[]
  profileChangeLogs   ProfileChangeLog[]
  complianceJourneys  ComplianceJourney[]
  humanCheckpoints    HumanCheckpoint[]
  agentEvents         AgentEvent[]
  profileVersions     BusinessProfileVersion[]
  // Phase 9
  controlApplicability ControlApplicability[]
  soc2Scopes          Soc2Scope[]
  iso27001Scopes      Iso27001Scope[]
  soaEntries          IsoStatementOfApplicability[]
  readinessScores     ReadinessScore[]
  dashboardConfigs    DashboardConfig[]
  auditExports        AuditExport[]
  riskTreatments      RiskTreatment[]
  // Phase 10 (Prompt 4)
  agentMemory         AgentMemory[]
  inferenceResults    InferenceResult[]
  integrationSuggestions IntegrationSuggestion[]
  llmBudget           LlmBudget?
  // Phase A (Control Test Engine + Trust Center)
  controlTestResults  ControlTestResult[]
  trustCenter         TrustCenter?
  // Phase B (Exceptions + Auditor Portal)
  controlExceptions   ControlException[]
  auditorSessions     AuditorSession[]
  auditorRfis         AuditorRfi[]
  // Phase C (Compliance Memory)
  auditCycles         AuditCycle[]
  auditFindings       AuditFinding[]
  // Team Management (Phase D)
  raciAssignments          RaciAssignment[]
  complianceResponsibilities ComplianceResponsibility[]
  teamAuditLogs            TeamAuditLog[]
  controlEvidence          ControlEvidence[]
  accessReviews            AccessReview[]
  trainingAssignments      TrainingAssignment[]
  controlEffectivenessSamples ControlEffectivenessSample[]
  managementReviews        ManagementReview[]

  @@map("organizations")
}

model User {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         UserRole  @default(member)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions              Session[]
  assignedControls      OrganizationControl[] @relation("ControlAssignee")
  reviewedEvidence      Evidence[]            @relation("EvidenceReviewer")
  approvedPolicies      Policy[]              @relation("PolicyApprover")
  triggeredWorkflows    Workflow[]            @relation("WorkflowTrigger")
  assignedTasks         Task[]               @relation("TaskAssignee")
  ownedRisks            RiskItem[]           @relation("RiskOwner")
  auditLogs             AuditLog[]
  onboardingSessions    OnboardingSession[]
  profileChangeLogs     ProfileChangeLog[]
  reviewedCheckpoints      HumanCheckpoint[]     @relation("CheckpointReviewer")
  profileVersionsAuthor    BusinessProfileVersion[]
  // Phase 9
  applicabilityOverrides   ControlApplicability[] @relation("ApplicabilityOverride")
  soc2ScopeApprovals       Soc2Scope[]            @relation("Soc2ScopeApprover")
  isoScopeApprovals        Iso27001Scope[]        @relation("IsoScopeApprover")
  riskTreatmentsOwned      RiskTreatment[]        @relation("RiskTreatmentOwner")
  riskTreatmentsAccepted   RiskTreatment[]        @relation("RiskTreatmentAcceptor")
  // Phase B (Exceptions + Auditor Portal)
  exceptionsOwned          ControlException[]     @relation("ExceptionRiskOwner")
  exceptionsReviewed       ControlException[]     @relation("ExceptionReviewer")
  auditorSessionsCreated   AuditorSession[]       @relation("AuditorSessionCreator")
  rfisResponded            AuditorRfi[]           @relation("RfiResponder")
  // Phase C (Compliance Memory)
  auditCyclesCreated       AuditCycle[]           @relation("AuditCycleCreator")
  findingsResolved         AuditFinding[]         @relation("FindingResolver")
  // Phase D (Team Management)
  platformRole             PlatformRole           @default(contributor) @map("platform_role")
  status                   UserStatus             @default(active)
  jobTitle                 String?                @map("job_title")
  department               String?
  managerId                String?                @map("manager_id")
  manager                  User?                  @relation("DirectReports", fields: [managerId], references: [id])
  directReports            User[]                 @relation("DirectReports")
  employmentType           EmploymentType?        @map("employment_type")
  startDate                DateTime?              @map("start_date")
  ndaSignedAt              DateTime?              @map("nda_signed_at")
  aupSignedAt              DateTime?              @map("aup_signed_at")
  backgroundCheckAt        DateTime?              @map("background_check_at")
  lastAccessReviewAt       DateTime?              @map("last_access_review_at")
  delegateId               String?                @map("delegate_id")
  delegateUntil            DateTime?              @map("delegate_until")
  delegate                 User?                  @relation("Delegate", fields: [delegateId], references: [id])
  delegatedFrom            User[]                 @relation("Delegate")
  responsibilities         ComplianceResponsibility[]
  raciAssignments          RaciAssignment[]
  authoredPolicies         Policy[]               @relation("PolicyAuthor")
  approvedTasks            Task[]                 @relation("TaskApprover")
  teamAuditLogsActed       TeamAuditLog[]         @relation("TeamAuditActor")
  accessReviewsConducted   AccessReview[]         @relation("AccessReviewer")
  accessReviewItems        AccessReviewItem[]     @relation("AccessReviewItemUser")
  trainingAssignments      TrainingAssignment[]   @relation("TrainingAssignee")
  trainingAssignedBy       TrainingAssignment[]   @relation("TrainingAssignedBy")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  orgId        String   @map("org_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isRevoked    Boolean  @default(false) @map("is_revoked")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Compliance Layer ─────────────────────────────────────────────────────────

model Framework {
  id          String        @id @default(uuid())
  name        String
  type        FrameworkType
  version     String
  description String?
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")

  controls       Control[]
  controlDomains ControlDomain[]

  @@unique([type, version])
  @@map("frameworks")
}

model Control {
  id          String   @id @default(uuid())
  frameworkId String   @map("framework_id")
  code        String
  title       String
  description String
  category    String
  guidance    String?
  weight      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  framework            Framework             @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  organizationControls OrganizationControl[]
  evidence             Evidence[]
  policies             Policy[]
  tasks                Task[]
  riskItems            RiskItem[]
  // Phase 9 relations
  libraryMeta          ControlLibraryMeta?
  evidenceRequirements ControlEvidenceRequirement[]
  policyRequirements   ControlPolicyRequirement[]
  crosswalkSources     FrameworkCrosswalk[]          @relation("CrosswalkSource")
  crosswalkTargets     FrameworkCrosswalk[]          @relation("CrosswalkTarget")
  applicability        ControlApplicability[]
  soaEntries           IsoStatementOfApplicability[]
  exceptions           ControlException[]
  auditorRfis          AuditorRfi[]
  auditFindings        AuditFinding[]
  controlEvidence      ControlEvidence[]
  raciAssignments      RaciAssignment[]

  @@unique([frameworkId, code])
  @@map("controls")
}

model OrganizationControl {
  id             String        @id @default(uuid())
  orgId          String        @map("org_id")
  controlId      String        @map("control_id")
  status         ControlStatus @default(not_started)
  score          Int           @default(0)
  assignedTo     String?       @map("assigned_to")
  dueDate        DateTime?     @map("due_date")
  notes          String?
  reviewStatus   ReviewStatus? @map("review_status")
  confidence     Confidence?
  lastReviewedAt DateTime?     @map("last_reviewed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("ControlAssignee", fields: [assignedTo], references: [id])

  @@unique([orgId, controlId])
  @@map("organization_controls")
}

model Evidence {
  id          String         @id @default(uuid())
  orgId       String         @map("org_id")
  controlId   String         @map("control_id")
  title       String
  type        EvidenceType
  source      EvidenceSource
  storageUrl  String?        @map("storage_url")
  metadata    Json           @default("{}")
  collectedAt DateTime       @default(now()) @map("collected_at")
  expiresAt   DateTime?      @map("expires_at")
  isValid     Boolean        @default(true) @map("is_valid")
  reviewedBy  String?        @map("reviewed_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  // Immutability — set when attached to an audit bundle, never mutated after
  frozenAt    DateTime?      @map("frozen_at")
  contentHash String?        @map("content_hash")  // SHA-256 of evidence data

  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control         Control             @relation(fields: [controlId], references: [id], onDelete: Cascade)
  reviewer        User?               @relation("EvidenceReviewer", fields: [reviewedBy], references: [id])
  testResults     ControlTestResult[]
  controlMappings ControlEvidence[]

  @@map("evidence")
}

model Policy {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  controlId   String       @map("control_id")
  title       String
  content     String
  version     Int          @default(1)
  status      PolicyStatus @default(draft)
  approvedBy  String?      @map("approved_by")
  approvedAt  DateTime?    @map("approved_at")
  generatedBy GeneratedBy  @default(agent) @map("generated_by")
  authorId    String?      @map("author_id")
  templateId  String?      @map("template_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control        @relation(fields: [controlId], references: [id], onDelete: Cascade)
  approver     User?          @relation("PolicyApprover", fields: [approvedBy], references: [id])
  author       User?          @relation("PolicyAuthor", fields: [authorId], references: [id])
  template     PolicyTemplate? @relation(fields: [templateId], references: [id])

  @@map("policies")
}

// ─── Agent Layer ──────────────────────────────────────────────────────────────

model Workflow {
  id             String         @id @default(uuid())
  orgId          String         @map("org_id")
  name           String
  type           WorkflowType
  status         WorkflowStatus @default(pending)
  inputPayload   Json           @default("{}") @map("input_payload")
  outputPayload  Json?          @map("output_payload")
  startedAt      DateTime?      @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  triggeredBy    String?        @map("triggered_by")
  createdAt      DateTime       @default(now()) @map("created_at")

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trigger           User?              @relation("WorkflowTrigger", fields: [triggeredBy], references: [id])
  agentRuns         AgentRun[]
  tasks             Task[]
  complianceJourney ComplianceJourney?

  @@map("workflows")
}

model AgentRun {
  id            String      @id @default(uuid())
  workflowId    String?     @map("workflow_id")
  orgId         String      @map("org_id")
  agentName     String      @map("agent_name")
  status        AgentStatus @default(pending)
  inputPayload  Json        @default("{}") @map("input_payload")
  outputPayload Json?       @map("output_payload")
  errorMessage  String?     @map("error_message")
  retryCount    Int         @default(0) @map("retry_count")
  startedAt     DateTime?   @map("started_at")
  completedAt   DateTime?   @map("completed_at")
  durationMs    Int?        @map("duration_ms")
  llmTokensUsed Int?        @map("llm_tokens_used")
  llmCostUsd    Decimal?    @map("llm_cost_usd") @db.Decimal(10, 6)
  createdAt     DateTime    @default(now()) @map("created_at")

  workflow         Workflow?          @relation(fields: [workflowId], references: [id])
  organization     Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steps            AgentStep[]
  onboardingSession OnboardingSession? @relation("OnboardingAgentRun")

  @@map("agent_runs")
}

model AgentStep {
  id              String     @id @default(uuid())
  runId           String     @map("run_id")
  stepName        String     @map("step_name")
  stepIndex       Int        @map("step_index")
  status          StepStatus @default(pending)
  inputSnapshot   Json       @default("{}") @map("input_snapshot")
  outputSnapshot  Json?      @map("output_snapshot")
  errorMessage    String?    @map("error_message")
  startedAt       DateTime?  @map("started_at")
  completedAt     DateTime?  @map("completed_at")
  durationMs      Int?       @map("duration_ms")

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("agent_steps")
}

// ─── Task Layer ───────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  controlId   String?      @map("control_id")
  workflowId  String?      @map("workflow_id")
  title       String
  description String?
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(open)
  assignedTo  String?      @map("assigned_to")
  dueDate     DateTime?    @map("due_date")
  source           TaskSource   @default(agent)
  // Guided task fields (Phase D)
  kind             TaskKind     @default(EVIDENCE_UPLOAD)
  isGuided         Boolean      @default(false) @map("is_guided")
  guidance         Json?
  dependsOn        String[]     @default([]) @map("depends_on")
  approvalRequired Boolean      @default(false) @map("approval_required")
  approverId       String?      @map("approver_id")
  approvedAt       DateTime?    @map("approved_at")
  recurrence       Json?
  estimatedMinutes Int?         @map("estimated_minutes")
  slaHours         Int?         @map("sla_hours")
  templateId       String?      @map("template_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control      Control?     @relation(fields: [controlId], references: [id])
  workflow     Workflow?    @relation(fields: [workflowId], references: [id])
  assignee     User?        @relation("TaskAssignee", fields: [assignedTo], references: [id])
  approver     User?        @relation("TaskApprover", fields: [approverId], references: [id])

  @@map("tasks")
}

// ─── Integration Layer ────────────────────────────────────────────────────────

model Integration {
  id           String              @id @default(uuid())
  orgId        String              @map("org_id")
  provider     IntegrationProvider
  status       IntegrationStatus   @default(pending)
  credentials  Json                @default("{}") // AES-256 encrypted at application layer
  lastSyncedAt DateTime?           @map("last_synced_at")
  settings     Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@map("integrations")
}

// ─── Risk Layer ───────────────────────────────────────────────────────────────

model RiskItem {
  id           String         @id @default(uuid())
  orgId        String         @map("org_id")
  controlId    String?        @map("control_id")
  title        String
  description  String?
  likelihood   RiskLikelihood
  impact       RiskImpact
  riskScore        Int            @map("risk_score") // computed: likelihood_value * impact_value
  severity         String?        // critical | high | medium | low (derived from riskScore)
  mitigationAdvice String?        @map("mitigation_advice") @db.Text
  status           RiskStatus     @default(open)
  owner            String?
  identifiedBy     GeneratedBy    @default(agent) @map("identified_by")
  identifiedAt     DateTime       @default(now()) @map("identified_at")
  reviewedAt       DateTime?      @map("reviewed_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  control        Control?        @relation(fields: [controlId], references: [id])
  riskOwner      User?           @relation("RiskOwner", fields: [owner], references: [id])
  riskTreatments RiskTreatment[]

  @@map("risk_items")
}

model VendorRisk {
  id             String     @id @default(uuid())
  orgId          String     @map("org_id")
  vendorName     String     @map("vendor_name")
  category       String?
  riskLevel      RiskLevel  @map("risk_level")
  assessment     Json       @default("{}")
  lastAssessedAt DateTime?  @map("last_assessed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("vendor_risks")
}

// ─── Onboarding Layer ─────────────────────────────────────────────────────────

model BusinessProfile {
  id               String       @id @default(uuid())
  orgId            String       @unique @map("org_id")
  version          Int          @default(1)
  companyName      String       @map("company_name")
  companyType      CompanyType  @map("company_type")
  industry         Industry
  subIndustry      String?      @map("sub_industry")
  employeeCount    String       @map("employee_count") // "11-50"
  engineeringCount String?      @map("engineering_count")
  foundedYear      Int?         @map("founded_year")
  hqCountry        String?      @map("hq_country")
  operatesIn       String[]     @map("operates_in")
  infrastructure   Json         @default("{}")
  tools            Json         @default("{}")
  dataHandling     Json         @default("{}") @map("data_handling")
  currentPosture   Json         @default("{}") @map("current_posture")
  complianceGoals  Json         @default("{}") @map("compliance_goals")
  riskProfile      Json         @default("{}") @map("risk_profile")
  confidenceScores Json         @default("{}") @map("confidence_scores")
  collectedVia     CollectedVia @default(onboarding_agent) @map("collected_via")
  isComplete       Boolean      @default(false) @map("is_complete")
  completedAt      DateTime?    @map("completed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model OnboardingSession {
  id                  String           @id @default(uuid())
  orgId               String           @map("org_id")
  userId              String           @map("user_id")
  status              OnboardingStatus @default(in_progress)
  currentState        String           @default("GREETING") @map("current_state")
  conversationHistory Json             @default("[]") @map("conversation_history")
  extractedData       Json             @default("{}") @map("extracted_data")
  turnCount           Int              @default(0) @map("turn_count")
  agentRunId          String?          @unique @map("agent_run_id")
  startedAt           DateTime         @default(now()) @map("started_at")
  completedAt         DateTime?        @map("completed_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentRun     AgentRun?    @relation("OnboardingAgentRun", fields: [agentRunId], references: [id])
  messages     OnboardingMessage[]

  @@map("onboarding_sessions")
}

model OnboardingMessage {
  id              String      @id @default(uuid())
  sessionId       String      @map("session_id")
  turnIndex       Int         @map("turn_index")
  role            MessageRole
  content         String
  extractedFields Json        @default("{}") @map("extracted_fields")
  stateAtTime     String      @map("state_at_time")
  createdAt       DateTime    @default(now()) @map("created_at")

  session OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("onboarding_messages")
}

model ProfileChangeLog {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  changedBy       String   @map("changed_by")
  previousProfile Json     @map("previous_profile")
  newProfile      Json     @map("new_profile")
  changeReason    String?  @map("change_reason")
  changedAt       DateTime @default(now()) @map("changed_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [changedBy], references: [id])

  @@map("profile_change_logs")
}

// ─── Logs Layer ───────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  userId       String?  @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SystemLog {
  id        String   @id @default(uuid())
  orgId     String?  @map("org_id")
  level     LogLevel
  source    String
  message   String
  context   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])

  @@map("system_logs")
}

// ─── Compliance Journey ────────────────────────────────────────────────────────

model ComplianceJourney {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  workflowId   String?       @unique @map("workflow_id")
  currentStage JourneyStage  @default(onboarding) @map("current_stage")
  status       JourneyStatus @default(active)

  // Accumulated structured outputs from every agent keyed by agentName
  agentOutputs Json @default("{}") @map("agent_outputs")

  // Ordered log of stage transitions: [{stage, status, timestamp, agentName, durationMs}]
  history Json @default("[]")

  // Human interventions: [{checkpointId, userId, action, notes, timestamp}]
  humanInterventions Json @default("[]") @map("human_interventions")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workflow     Workflow?           @relation(fields: [workflowId], references: [id])
  checkpoints  HumanCheckpoint[]

  @@map("compliance_journeys")
}

// ─── Human Checkpoints ────────────────────────────────────────────────────────

model HumanCheckpoint {
  id             String           @id @default(uuid())
  orgId          String           @map("org_id")
  journeyId      String           @map("journey_id")
  workflowId     String?          @map("workflow_id")
  checkpointType CheckpointType   @map("checkpoint_type")
  status         CheckpointStatus @default(pending)
  agentName      String           @map("agent_name")

  // Structured review content generated by the Review/Audit agent
  summary       String? @db.Text
  findings      Json    @default("[]")
  risks         Json    @default("[]")
  uncertainties Json    @default("[]")
  metrics       Json    @default("{}") // score, controlsImplemented, evidenceCount etc.

  // Human decision
  reviewerId  String?   @map("reviewer_id")
  reviewedAt  DateTime? @map("reviewed_at")
  decision    String?   // approved | rejected | override
  comments    String?   @db.Text
  overrideReason String? @map("override_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journey      ComplianceJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  reviewer     User?         @relation("CheckpointReviewer", fields: [reviewerId], references: [id])

  @@map("human_checkpoints")
}

// ─── Agent Event Log ──────────────────────────────────────────────────────────

model AgentEvent {
  id         String         @id @default(uuid())
  orgId      String         @map("org_id")
  workflowId String?        @map("workflow_id")
  journeyId  String?        @map("journey_id")
  runId      String?        @map("run_id")
  agentName  String         @map("agent_name")
  eventType  AgentEventType @map("event_type")
  payload    Json           @default("{}")
  createdAt  DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, workflowId])
  @@index([orgId, agentName])
  @@map("agent_events")
}

// ─── Business Profile Versions ────────────────────────────────────────────────

model BusinessProfileVersion {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  version      Int
  snapshot     Json     // full BusinessProfile data at this point in time
  changedById  String   @map("changed_by_id")
  changeReason String?  @map("change_reason") @db.Text
  diff         Json     @default("{}") // fields that changed vs previous version
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  changedBy    User         @relation(fields: [changedById], references: [id])

  @@unique([orgId, version])
  @@map("business_profile_versions")
}

// ─── Onboarding Dialogue State ────────────────────────────────────────────────

model DialogueState {
  id              String   @id @default(uuid())
  orgId           String   @unique @map("org_id")
  sessionId       String   @map("session_id")
  currentTopic    String   @map("current_topic")   // which field cluster we are probing
  completedFields Json     @default("[]") @map("completed_fields")
  pendingFields   Json     @default("[]") @map("pending_fields")
  questionHistory Json     @default("[]") @map("question_history") // [{question, answer, field, confidence}]
  turnCount       Int      @default(0) @map("turn_count")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("dialogue_states")
}

