# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
# Full public URL of this API — used in SSO SP metadata / ACS callback URLs (P23)
APP_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
# Uses pgvector/pgvector:pg16 in Docker (see docker-compose.yml)
# Run after first start:
#   npx prisma migrate deploy          (Prisma schema migrations)
#   psql $DATABASE_URL -f ../setup.sql  (pgvector, FTS, SSO table, retention columns)
DATABASE_URL="postgresql://compliance:compliance_secret@localhost:5432/compliance_db?schema=public"

# ─── Redis (BullMQ queue backend) ─────────────────────────────────────────────
# Either use REDIS_URL (Railway, Render, Upstash) or host/port/password (Docker)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set ENABLE_MOCK_LLM=true for local development without real API keys
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ─── OpenRouter (Semantic Search Embeddings + AI Features) ────────────────────
# Used by EmbeddingService (P20) for semantic document search via text-embedding-3-small.
# Also used by AiFeaturesService for document improve/gap detection (claude-haiku-3-5).
# Get a key at: https://openrouter.ai/keys
# Falls back to OPENAI_API_KEY if this is not set.
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Embeddings (RAG / pgvector) ──────────────────────────────────────────────
# Legacy Voyage embeddings — superseded by OpenRouter in P20.
# Kept for backward compat; OPENROUTER_API_KEY takes priority.
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=pa-...

# ─── Mock / Development Flags ─────────────────────────────────────────────────
# true = deterministic mock LLM responses (no API key required)
ENABLE_MOCK_LLM=false
# true = skip embedding generation entirely (semantic search returns no results)
ENABLE_MOCK_EMBEDDINGS=false
# true = in-memory vector store fallback instead of pgvector
ENABLE_RAG_IN_MEMORY_FALLBACK=false

# ─── Collaborative Editing (Yjs / Hocuspocus) — P22 ──────────────────────────
# Set to "true" to start the Hocuspocus WebSocket server alongside NestJS.
# Requires Redis to be running (used for pub/sub between server instances).
# Feature also gated by feature flag: documents.collaborativeEdit
COLLABORATION_ENABLED=false
COLLABORATION_PORT=1234

# ─── Storage (S3-compatible, for evidence files + document exports) ───────────
# STORAGE_PROVIDER: "local" (saves to ./uploads/) | "s3" | "r2" | "gcs"
# For production, use "s3" with an AWS S3 bucket or Cloudflare R2 (S3-compatible).
STORAGE_PROVIDER=local
S3_BUCKET=ai-compliance-copilot-evidence
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For R2 / GCS or any S3-compatible endpoint override:
S3_ENDPOINT=

# ─── Encryption (optional) ────────────────────────────────────────────────────
KMS_KEY_ID=
ENCRYPTION_KEY=

# ─── Observability (optional) ─────────────────────────────────────────────────
# Point to any OpenTelemetry-compatible collector (Jaeger, Honeycomb, Datadog, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── GitHub OAuth (for real OAuth integration flow) ───────────────────────────
# Create at: github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3001/api/v1/integrations/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Base URL of this API (used to build the OAuth callback URL)
API_BASE_URL=http://localhost:3001

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Create at: resend.com → API Keys
# For local dev, use the onboarding@resend.dev sandbox (no domain verification needed)
RESEND_API_KEY=re_...
# Your verified sending domain (optional — omit for resend.dev sandbox)
RESEND_FROM_DOMAIN=

# ─── Credential Encryption ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Used to encrypt connector credentials (AWS, Slack, GitHub) stored in the database
LOCAL_SECRET_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
