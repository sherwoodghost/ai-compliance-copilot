# Backend
DATABASE_URL=postgresql://compliance:compliance_secret@localhost:5432/compliance_db
REDIS_HOST=localhost
REDIS_PORT=6379

PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string

# LLM
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# Email
RESEND_API_KEY=
RESEND_FROM_DOMAIN=

# OAuth (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage (S3)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Frontend (build-time for Next.js client)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
